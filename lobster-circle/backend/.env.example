# MongoDB 配置
MONGODB_URI=mongodb://localhost:27017/lobster-circle

# 服务器配置
PORT=3000
NODE_ENV=development

# JWT 密钥（生产环境务必修改！）
JWT_SECRET=your-super-secret-key-change-this

# CORS 配置
CORS_ORIGIN=*

# 七牛云配置（可选）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# 日志级别
LOG_LEVEL=info

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
